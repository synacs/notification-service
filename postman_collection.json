        {
            "name": "1. Отправка уведомлений",
            "item": [
                {
                    "name": "Email рассылка (приоритет 5)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const jsonData = pm.response.json();",
                                    "",
                                    "pm.test(\"Status 201\", function() {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test(\"Has batch_id\", function() {",
                                    "    pm.expect(jsonData).to.have.property('batch_id');",
                                    "});",
                                    "",
                                    "if (jsonData.batch_id) {",
                                    "    pm.collectionVariables.set('BATCH_ID', jsonData.batch_id);",
                                    "    pm.collectionVariables.set('LAST_BATCH_ID', jsonData.batch_id);",
                                    "    console.log('Batch ID saved:', jsonData.batch_id);",
                                    "    console.log('Now execute \"Batch Details\" request');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Idempotency-Key",
                                "value": "{{$randomUUID}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"channel\": \"email\",\n  \"recipients\": [\n    \"user1@example.com\",\n    \"user2@example.com\",\n    \"user3@example.com\"\n  ],\n  \"message\": \"Welcome to our service! Your account has been created.\",\n  \"priority\": 5\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}/api/notifications/bulk",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "api",
                                "notifications",
                                "bulk"
                            ]
                        }
                    },
                    "response": []
                },
