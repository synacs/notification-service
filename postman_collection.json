                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"channel\": \"email\",\n  \"recipients\": [\"idempotent@example.com\"],\n  \"message\": \"Idempotency test message\",\n  \"priority\": 5\n}"
