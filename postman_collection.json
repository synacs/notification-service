                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const jsonData = pm.response.json();",
                                    "const firstBatchId = pm.collectionVariables.get('IDEMPOTENT_BATCH_ID');",
                                    "",
                                    "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                                    "pm.test(\"Batch ID matches first request\", () => {",
                                    "    pm.expect(jsonData.batch_id).to.equal(firstBatchId);",
                                    "});",
                                    "",
                                    "console.log('Idempotency works! Both requests returned:', jsonData.batch_id);"
                                ],
                                "type": "text/javascript"
                            }
