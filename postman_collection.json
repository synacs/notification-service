        {
            "name": "3. Получение информации",
            "item": [
                {
                    "name": "Детали batch по ID",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "const batchId = pm.collectionVariables.get('BATCH_ID');",
                                    "if (!batchId) {",
                                    "    console.warn('Warning: No BATCH_ID set. Send a notification first.');",
                                    "} else {",
                                    "    console.log('Fetching batch:', batchId);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const jsonData = pm.response.json();",
                                    "",
                                    "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                                    "pm.test(\"Has batch_id\", () => jsonData.batch_id);",
                                    "pm.test(\"Has statistics\", () => {",
                                    "    pm.expect(jsonData).to.have.property('total_count');",
                                    "    pm.expect(jsonData).to.have.property('sent_count');",
                                    "    pm.expect(jsonData).to.have.property('failed_count');",
                                    "});",
                                    "",
                                    "console.log('Batch statistics:', {",
                                    "    total: jsonData.total_count,",
                                    "    sent: jsonData.sent_count,",
                                    "    failed: jsonData.failed_count,",
                                    "    processing: jsonData.processing_count",
                                    "});",
                                    "",
                                    "if (jsonData.data && jsonData.data.length > 0) {",
                                    "    pm.collectionVariables.set('NOTIFICATION_ID', jsonData.data[0].id);",
                                    "    console.log('Saved notification_id:', jsonData.data[0].id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}/api/notifications/batches/{{BATCH_ID}}",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "api",
                                "notifications",
                                "batches",
                                "{{BATCH_ID}}"
                            ]
                        }
                    },
                    "response": []
